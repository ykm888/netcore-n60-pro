# ================================================================
# 磊科 N60 Pro - 237高功率闭源驱动 & 极致性能精简固件
# 核心目标：原厂高功率信号、仅内置 SSR Plus+、预留 Docker 内核依赖
# 适用底座：基于 237 大佬驱动的 ImmortalWrt / OpenWrt 24.10 源码
# ================================================================

# ------------------------- 1. 目标硬件平台 -------------------------
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_netcore_n60-pro=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_INITRAMFS_COMPRESSION_NONE=y

# ------------------------- 2. 237大佬闭源高功率无线驱动 -------------------------
# 必须彻底禁用开源无线驱动，防止内核冲突
# CONFIG_PACKAGE_kmod-mt7915e is not set
# CONFIG_PACKAGE_kmod-mt7915-firmware is not set

# 启用237源码特有的联发科闭源原厂驱动及LuCI控制面板
CONFIG_PACKAGE_kmod-mt_wifi=y
CONFIG_PACKAGE_luci-app-mtwifi=y
CONFIG_PACKAGE_kmod-mediatek_hnat=y

# ------------------------- 3. 内核与网络极致性能调优 -------------------------
CONFIG_KERNEL_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_KERNEL_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_KERNEL_PREEMPT=y
CONFIG_KERNEL_HIGH_RES_TIMERS=y
CONFIG_DEFAULT_BBR=y

# 极大化网络套接字缓冲区，防止千兆并发丢包
CONFIG_KERNEL_NET_CORE_RMEM_DEFAULT=262144
CONFIG_KERNEL_NET_CORE_WMEM_DEFAULT=262144
CONFIG_KERNEL_NET_CORE_RMEM_MAX=16777216
CONFIG_KERNEL_NET_CORE_WMEM_MAX=16777216

# 硬件加速组件
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_kmod-ipt-offload=y
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_irqbalance=y

# ------------------------- 4. Docker 内核依赖（仅内核，应用后装） -------------------------
# 核心容器技术依赖（确保 opkg 后装 docker-ce 时不需要重新编译内核）
CONFIG_PACKAGE_kmod-cgroup-cpu=y
CONFIG_PACKAGE_kmod-cgroup-cpuset=y
CONFIG_PACKAGE_kmod-cgroup-freezer=y
CONFIG_PACKAGE_kmod-cgroup-memory=y
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmod-lib-crc32c=y
CONFIG_PACKAGE_cgroupfs-mount=y
CONFIG_PACKAGE_kmod-br-netfilter=y

# 严格禁用 Docker 实体应用，防止撑大固件体积
# CONFIG_PACKAGE_docker-ce is not set
# CONFIG_PACKAGE_dockerd is not set
# CONFIG_PACKAGE_luci-app-dockerman is not set
# CONFIG_PACKAGE_docker-compose is not set

# ------------------------- 5. USB 与外部存储（Docker 容器存放必备） -------------------------
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-uas=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-scsi-core=y

# 常用文件系统支持（建议外挂 U 盘/固态硬盘格式化为 ext4 或 f2fs）
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-nls-utf8=y

# ------------------------- 6. 科学上网 (仅 SSR Plus+ 及核心) -------------------------
# 网络层级依赖
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_libopenssl=y

# SSR Plus+ 主程序与中文语言包
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-i18n-ssr-plus-zh-cn=y

# 核心 Xray 保持开箱即用
CONFIG_PACKAGE_xray-core=y

# ------------------------- 7. 基础 LuCI 界面与核心工具 -------------------------
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-theme-argon=y

# DNS与网络核心替换
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcp=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y

# 基础必备网络与系统工具
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_gzip=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_e2fsprogs=y

# IPv6 与基础网络通迅保障
CONFIG_PACKAGE_odhcpd=y
CONFIG_PACKAGE_odhcpd-extras=y
CONFIG_DEFAULT_firewall=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_tzdata=y
